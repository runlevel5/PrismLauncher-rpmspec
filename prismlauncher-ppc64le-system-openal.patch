--- a/launcher/Application.cpp
+++ b/launcher/Application.cpp
@@ -757,8 +757,19 @@
         m_settings->registerSetting("OnlineFixes", false);
 
         // Native library workarounds
+#if defined(__powerpc64__)
+        // The bundled LWJGL OpenAL native crashes in a libc exit handler during
+        // shutdown on ppc64le (SIGSEGV in __run_exit_handlers). Default to the
+        // system openal-soft, which is built correctly for this platform. The
+        // explicit SONAME path avoids depending on the -devel symlink that Prism's
+        // dlopen()-based detection would otherwise require. (openal-soft is a
+        // package dependency of this build.)
+        m_settings->registerSetting("UseNativeOpenAL", true);
+        m_settings->registerSetting("CustomOpenALPath", "/usr/lib64/libopenal.so.1");
+#else
         m_settings->registerSetting("UseNativeOpenAL", false);
         m_settings->registerSetting("CustomOpenALPath", "");
+#endif
         m_settings->registerSetting("UseNativeGLFW", false);
         m_settings->registerSetting("CustomGLFWPath", "");
 
